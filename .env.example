# =============================================================================
# YoFounder — environment variables
# =============================================================================
# Copy this file to .env.local for local dev, and paste the same names into
# Vercel → Project Settings → Environment Variables for production.
#
# On Lovable Cloud the VITE_SUPABASE_* and SUPABASE_* values are auto-injected
# and .env is auto-generated — you don't need this file there.
# =============================================================================

# ----- Supabase (REQUIRED) ---------------------------------------------------
# From: Supabase Dashboard → Project Settings → API
# Client-visible (safe to expose, bundled into the browser build):
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_PUBLIC_KEY
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Server-only mirrors of the above (same values, no VITE_ prefix).
# Used by SSR and server functions running on Vercel.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_PUBLIC_KEY

# Service role — NEVER expose to the browser. Bypasses RLS.
# Used by admin server functions (invites, etc.).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ----- AI providers (REQUIRED for AI chat) -----------------------------------
# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Lovable AI Gateway (optional — only if you want to keep using Lovable's
# managed AI proxy after moving off Lovable Cloud)
LOVABLE_API_KEY=

# ----- Email (REQUIRED for workspace invites) --------------------------------
# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# =============================================================================
# Auth provider setup (no env vars — configured in Supabase Dashboard)
# =============================================================================
# Authentication → Providers:
#   - Email: enable
#   - Google: enable + paste OAuth client id/secret
#   - GitHub: enable + paste OAuth App client id/secret
#
# Authentication → URL Configuration:
#   Site URL:       https://yo-founder.com
#   Redirect URLs:  https://yo-founder.com/**
#                   https://*.vercel.app/**
#                   http://localhost:3000/**
#                   http://localhost:8080/**
#
# GitHub OAuth App callback URL must be:
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
# =============================================================================
